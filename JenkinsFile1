pipeline {
    agent any

    tools {
        jdk 'myjava'
        maven 'mymaven131'
    }

    stages {

        stage('Checkout TT') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/toothlessnoob/DevOpsCodes.git'
            }
        }

        stage('Compile') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Code Review (PMD)') {
            steps {
                sh 'mvn pmd:pmd'
            }
        }

        stage('Unit Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Metric Check (Coverage)') {
            steps {
                sh '''
                    mvn cobertura:cobertura || echo "⚠️ Coverage failed but pipeline continues"
                '''
            }
        }

        stage('Package') {
            steps {
                sh 'mvn package'
            }
        }
    }

    post {
        success {
            echo "🚀 Pipeline SUCCESS"
        }
        failure {
            echo "❌ Pipeline FAILED"
        }
    }
}
